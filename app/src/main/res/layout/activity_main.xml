<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
xmlns:android="http://schemas.android.com/apk/res/android"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:gravity="center"
android:orientation="vertical"
android:background="#08111F"
android:padding="28dp">

<TextView
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:text="DELAY LAUNCHER"
android:textStyle="bold|italic"
android:textSize="38sp"
android:textColor="#7EEBFF"
android:layout_marginBottom="28dp"/>

<Spinner
android:id="@+id/delaySpinner"
android:layout_width="300dp"
android:layout_height="wrap_content"
android:background="@drawable/input_bg"/>

<Spinner
android:id="@+id/appSpinner"
android:layout_width="300dp"
android:layout_height="wrap_content"
android:layout_marginTop="18dp"
android:background="@drawable/input_bg"/>

<Spinner
android:id="@+id/preApp1Spinner"
android:layout_width="300dp"
android:layout_height="wrap_content"
android:layout_marginTop="18dp"
android:background="@drawable/input_bg"/>

<Spinner
android:id="@+id/preApp2Spinner"
android:layout_width="300dp"
android:layout_height="wrap_content"
android:layout_marginTop="18dp"
android:background="@drawable/input_bg"/>

<Button
android:id="@+id/startButton"
android:layout_width="300dp"
android:layout_height="60dp"
android:text="START"
android:textStyle="bold"
android:textSize="22sp"
android:textColor="#FFFFFF"
android:background="@drawable/button_bg"
android:layout_marginTop="28dp"/>

<FrameLayout
android:id="@+id/circleContainer"
android:visibility="gone"
android:layout_width="260dp"
android:layout_height="260dp"
android:layout_marginTop="40dp">

<ProgressBar
android:id="@+id/circleProgress"
style="?android:attr/progressBarStyleHorizontal"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:max="100"/>

<TextView
android:id="@+id/circleText"
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:layout_gravity="center"
android:textSize="72sp"
android:textStyle="bold"
android:textColor="#FFFFFF"/>

</FrameLayout>

</LinearLayout>
