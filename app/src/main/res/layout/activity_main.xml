<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
xmlns:android="http://schemas.android.com/apk/res/android"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:orientation="vertical"
android:gravity="center"
android:background="#08111F"
android:padding="34dp">

<TextView
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:text="DELAY LAUNCHER"
android:textColor="#7EEBFF"
android:textStyle="bold"
android:textSize="44sp"
android:letterSpacing=".08"
android:layout_marginBottom="12dp"/>

<TextView
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:text="Launch Control"
android:textColor="#9ECFE3"
android:textSize="20sp"
android:layout_marginBottom="42dp"/>

<Spinner
android:id="@+id/delaySpinner"
android:layout_width="360dp"
android:layout_height="wrap_content"
android:minHeight="64dp"
android:background="@drawable/input_bg"
android:popupBackground="#DCE6EC"/>

<Spinner
android:id="@+id/appSpinner"
android:layout_width="360dp"
android:layout_height="wrap_content"
android:minHeight="64dp"
android:background="@drawable/input_bg"
android:popupBackground="#DCE6EC"
android:layout_marginTop="24dp"/>

<Button
android:id="@+id/startButton"
android:layout_width="360dp"
android:layout_height="66dp"
android:text="START"
android:textSize="24sp"
android:textStyle="bold"
android:textColor="#FFFFFF"
android:background="@drawable/button_bg"
android:layout_marginTop="34dp"/>

<FrameLayout
android:id="@+id/circleContainer"
android:visibility="gone"
android:layout_width="280dp"
android:layout_height="280dp"
android:layout_marginTop="52dp">

<ProgressBar
android:id="@+id/circleProgress"
style="?android:attr/progressBarStyleHorizontal"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:max="100"/>

<TextView
android:id="@+id/circleText"
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:layout_gravity="center"
android:textColor="#FFFFFF"
android:textSize="78sp"
android:textStyle="bold"/>

</FrameLayout>

</LinearLayout>
