<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@mipmap/ic_launcher"
        android:alpha="0.08"
        android:scaleType="centerInside"
        android:contentDescription="" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="28dp"
            android:paddingBottom="36dp">

            <LinearLayout
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="24dp"
                android:elevation="6dp"
                android:background="@drawable/ui_card_bg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Delay Launcher"
                    android:textStyle="bold"
                    android:textSize="24sp"
                    android:textColor="#24323A"
                    android:layout_marginBottom="22dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="App preliminare 1"
                    android:textSize="16sp"
                    android:textColor="#24323A"
                    android:drawableStart="@drawable/ic_phone_small"
                    android:drawablePadding="8dp"/>

                <Spinner
                    android:id="@+id/preApp1Spinner"
                    android:layout_width="230dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/spinner_field_bg"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="App preliminare 2"
                    android:textSize="16sp"
                    android:textColor="#24323A"
                    android:layout_marginTop="18dp"
                    android:drawableStart="@drawable/ic_phone_small"
                    android:drawablePadding="8dp"/>

                <Spinner
                    android:id="@+id/preApp2Spinner"
                    android:layout_width="230dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/spinner_field_bg"/>

                <View
                    android:layout_width="220dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="22dp"
                    android:layout_marginBottom="22dp"
                    android:background="@drawable/fade_divider"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ritardo secondi"
                    android:textSize="16sp"
                    android:textColor="#24323A"
                    android:drawableStart="@drawable/ic_timer_small"
                    android:drawablePadding="8dp"/>

                <Spinner
                    android:id="@+id/delaySpinner"
                    android:layout_width="125dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/spinner_field_bg"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Launcher principale"
                    android:textSize="16sp"
                    android:textColor="#24323A"
                    android:layout_marginTop="20dp"
                    android:drawableStart="@drawable/ic_rocket_small"
                    android:drawablePadding="8dp"/>

                <Spinner
                    android:id="@+id/launcherSpinner"
                    android:layout_width="230dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/spinner_field_bg"/>

                <Button
                    android:id="@+id/startButton"
                    android:layout_width="170dp"
                    android:layout_height="52dp"
                    android:layout_marginTop="28dp"
                    android:text="AVVIO"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/start_button_bg"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <FrameLayout
        android:id="@+id/countdownOverlay"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#DD000000">

        <ProgressBar
            android:id="@+id/circularProgress"
            android:layout_gravity="center"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:max="100"
            android:indeterminate="false"
            android:progressDrawable="@drawable/circular_progress"/>

        <TextView
            android:id="@+id/countdownNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="42sp"
            android:layout_gravity="center"/>

        <TextView
            android:id="@+id/countdownLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="sec"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_gravity="center"
            android:translationY="30dp"/>

    </FrameLayout>

</FrameLayout>
