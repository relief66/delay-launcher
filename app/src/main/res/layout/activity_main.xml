<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:background="#101010">

<ScrollView
android:layout_width="match_parent"
android:layout_height="match_parent">

<LinearLayout
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:orientation="vertical"
android:padding="24dp">

<TextView
android:text="Main Launcher"
android:textColor="#A5D6FF"
android:textSize="18sp"
android:layout_width="wrap_content"
android:layout_height="wrap_content"/>

<Spinner
android:id="@+id/launcherSpinner"
android:layout_width="match_parent"
android:layout_height="wrap_content"/>

<TextView
android:text="Countdown Delay"
android:textColor="#A5D6FF"
android:textSize="18sp"
android:layout_marginTop="18dp"
android:layout_width="wrap_content"
android:layout_height="wrap_content"/>

<Spinner
android:id="@+id/delaySpinner"
android:layout_width="match_parent"
android:layout_height="wrap_content"/>

<View
android:layout_width="match_parent"
android:layout_height="1dp"
android:layout_marginTop="22dp"
android:layout_marginBottom="22dp"
android:background="#446688"/>

<TextView
android:text="Pre-launch App 1 (Optional)"
android:textColor="#A5D6FF"
android:textSize="18sp"
android:layout_width="wrap_content"
android:layout_height="wrap_content"/>

<Spinner
android:id="@+id/preApp1Spinner"
android:layout_width="match_parent"
android:layout_height="wrap_content"/>

<TextView
android:text="Pre-launch App 2 (Optional)"
android:textColor="#A5D6FF"
android:textSize="18sp"
android:layout_marginTop="18dp"
android:layout_width="wrap_content"
android:layout_height="wrap_content"/>

<Spinner
android:id="@+id/preApp2Spinner"
android:layout_width="match_parent"
android:layout_height="wrap_content"/>

<Button
android:id="@+id/startButton"
android:text="AVVIA"
android:layout_marginTop="32dp"
android:layout_width="match_parent"
android:layout_height="60dp"/>

</LinearLayout>

</ScrollView>


<LinearLayout
android:id="@+id/countdownOverlay"
android:visibility="gone"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:background="#DD000000"
android:gravity="center"
android:orientation="vertical"
android:clickable="true"
android:focusable="true">

<ProgressBar
android:id="@+id/countdownCircle"
style="?android:attr/progressBarStyleLarge"
android:indeterminate="true"
android:layout_width="170dp"
android:layout_height="170dp"/>

<TextView
android:id="@+id/countdownText"
android:text="10"
android:textSize="56sp"
android:textStyle="bold"
android:textColor="#FFFFFF"
android:layout_marginTop="26dp"
android:layout_width="wrap_content"
android:layout_height="wrap_content"/>

</LinearLayout>

</FrameLayout>
