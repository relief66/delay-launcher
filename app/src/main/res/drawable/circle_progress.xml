<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- SFONDO -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#101820"/>
        </shape>
    </item>

    <!-- CERCHIO ANIMATO -->
    <item>
        <rotate android:fromDegrees="270" android:toDegrees="270">
            <shape
                android:shape="ring"
                android:useLevel="true"
                android:thickness="14dp">

                <gradient
                    android:startColor="#00E676"
                    android:centerColor="#00C853"
                    android:endColor="#00E676"
                    android:angle="0"/>
            </shape>
        </rotate>
    </item>

</layer-list>
