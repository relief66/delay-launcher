<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Stato focus / pressed leggermente più saturo -->
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#BDDDEB"/>
            <corners android:radius="14dp"/>
            <stroke
                android:width="1dp"
                android:color="#9EB8C4"/>
        </shape>
    </item>

    <item android:state_focused="true">
        <shape>
            <solid android:color="#BDDDEB"/>
            <corners android:radius="14dp"/>
            <stroke
                android:width="1dp"
                android:color="#9EB8C4"/>
        </shape>
    </item>

    <!-- Default -->
    <item>
        <shape>
            <solid android:color="#CFE8F3"/>
            <corners android:radius="14dp"/>
            <stroke
                android:width="1dp"
                android:color="#9EB8C4"/>
        </shape>
    </item>

</selector>
